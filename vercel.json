{
  "version": 2,
  "builds": [
    {
      "src": "frontend/templates/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/static/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "(.*)",
      "dest": "frontend/templates/$1"
    }
  ]
}
